# ===========================================
# Valorant Premier Dashboard - Backend
# ===========================================
# Copia este archivo como .env y completa los valores

# --- Valorant API (obligatorio) ---
# Obtén tu key en https://api.henrikdev.xyz/dashboard/
VALORANT_API_KEY=HDEV-your_api_key_here
VALORANT_API_BASE_URL=https://api.henrikdev.xyz/valorant/v3

# --- Database (obligatorio) ---
# Local con Docker: postgresql://valorant:valorant123@db:5432/valorant_dashboard
# Supabase: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://valorant:valorant123@db:5432/valorant_dashboard

# --- Demo Mode ---
# false = acceso completo (self-hosted)
# true = vista limitada (hosted en Vercel/Render)
DEMO_MODE=false
DEMO_LEADERBOARD_LIMIT=5
DEMO_SEARCH_LIMIT=3
DEMO_MATCH_HISTORY_LIMIT=5

# --- Security (obligatorio) ---
# Genera uno: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Google OAuth (opcional) ---
# Crear en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- CORS ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- Email (obligatorio si DEMO_MODE=true) ---
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# --- Cache TTL (segundos) - opcional ---
# CACHE_TTL_LEADERBOARD=900
# CACHE_TTL_TEAM=300
# CACHE_TTL_PLAYER=300
# CACHE_TTL_MATCH=600
# CACHE_TTL_MMR=300
