.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# Packaging / build
*.egg
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Jupyter / IPython
.ipynb_checkpoints/

